{
  "name": "@worksythongnguyen-ux/knky-ui",
  "version": "0.1.0",
  "description": "React component library generated from the Figma design system KNKY.",
  "repository": {
    "type": "git",
    "url": "https://github.com/worksythongnguyen-ux/knky-designsystem.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "./dist/knky-ui.cjs.js",
  "module": "./dist/knky-ui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/knky-ui.es.js",
      "require": "./dist/knky-ui.cjs.js"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --emitDeclarationOnly && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^3.9.0",
    "storybook": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6"
  }
}
